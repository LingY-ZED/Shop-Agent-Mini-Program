/* pages/login/login.wxss */
.login-page {
  position: relative;
  min-height: 100vh;
  background: linear-gradient(180deg, #ffffff 0%, #f8fbff 42%, #ffffff 100%);
  overflow: hidden;
}

.bg-glow {
  position: absolute;
  border-radius: 999rpx;
  filter: blur(6rpx);
  pointer-events: none;
}

.glow-left {
  width: 380rpx;
  height: 380rpx;
  top: -110rpx;
  left: -110rpx;
  background: radial-gradient(
    circle,
    rgba(66, 133, 244, 0.18) 0%,
    rgba(66, 133, 244, 0) 72%
  );
}

.glow-right {
  width: 360rpx;
  height: 360rpx;
  right: -120rpx;
  top: 320rpx;
  background: radial-gradient(
    circle,
    rgba(217, 101, 112, 0.18) 0%,
    rgba(217, 101, 112, 0) 70%
  );
}

.login-container {
  position: relative;
  z-index: 1;
  min-height: 100vh;
  padding: calc(64rpx + env(safe-area-inset-top)) 52rpx
    calc(52rpx + env(safe-area-inset-bottom));
  display: flex;
  flex-direction: column;
}

.header {
  margin-bottom: 72rpx;
}

.title-line {
  display: block;
  font-size: 62rpx;
  line-height: 1.3;
  font-weight: 700;
  color: #1f1f1f;
}

.subtitle {
  display: block;
  margin-top: 24rpx;
  color: #444746;
  font-size: 30rpx;
  line-height: 1.6;
}

.form-container {
  width: 100%;
}

.input-group {
  margin-bottom: 24rpx;
}

.input {
  width: 100%;
  height: 100rpx;
  border-radius: 24rpx;
  background-color: #f0f4f9;
  border: 2rpx solid transparent;
  padding: 0 28rpx;
  color: #1f1f1f;
  font-size: 30rpx;
  box-sizing: border-box;
}

.ph-style {
  color: #7b7f83;
}

.btn-primary {
  margin-top: 42rpx;
  height: 104rpx;
  line-height: 104rpx;
  width: 100%;
  border-radius: 54rpx;
  background: #1a73e8;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 500;
  box-shadow: 0 14rpx 34rpx rgba(26, 115, 232, 0.24);
}

.btn-primary::after {
  border: none;
}

.toggle-action {
  margin-top: 30rpx;
  text-align: center;
}

.toggle-link {
  color: #1a73e8;
  font-size: 28rpx;
  padding: 14rpx 18rpx;
}
