/**index.wxss**/
.chat-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #ffffff;
}

.chat-area {
  flex: 1;
  overflow: hidden;
  box-sizing: border-box;
}

.message-list {
  padding-bottom: 200rpx;
}

.message-row {
  display: flex;
  padding: 30rpx 40rpx;
  align-items: flex-start;
  border-bottom: 1px solid rgba(0,0,0,0.05); /* 可选保留 */
}

/* 我发的消息整行背景与AI可区分或不变 */
.my-row {
  background-color: #ffffff;
}
.bot-row {
  background-color: #f6f6f6;
}

.message-content-wrapper {
  display: flex;
  align-items: flex-start;
  width: 100%;
  max-width: 1400rpx;
  margin: 0 auto;
}

/* 控制用户对话在右侧 */
.my-row .message-content-wrapper {
  flex-direction: row-reverse;
}

.bot-row .message-content-wrapper {
  flex-direction: row;
}

.avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #fff;
  flex-shrink: 0;
  font-weight: bold;
  overflow: hidden; /* 让图片切圆角 */
}

.avatar-img {
  width: 100%;
  height: 100%;
}

.bot-avatar {
  background-color: #10a37f;
  margin-right: 24rpx;
}

.my-avatar {
  background-color: #576b95;
  margin-left: 24rpx;
}

.message-bubble {
  max-width: 75%;
  word-break: break-all;
  display: flex;
  flex-direction: column;
  color: #374151;
}

/* AI 的对话气泡样式 */
.bot-row .message-bubble {
  background-color: #ffffff;
  padding: 24rpx 30rpx;
  border-radius: 4rpx 24rpx 24rpx 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.02);
}

/* 用户自己的对话气泡样式 */
.my-row .message-bubble {
  background-color: #10a37f;
  padding: 24rpx 30rpx;
  border-radius: 24rpx 4rpx 24rpx 24rpx;
  color: #ffffff;
}

.message-text {
  font-size: 32rpx;
  line-height: 1.6;
}

.my-row .message-text {
  color: #ffffff;
}

.tool-tag {
  margin-top: 16rpx;
  display: inline-flex;
  background-color: #f0f0f0;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  align-self: flex-start;
}

.tag-text {
  font-size: 24rpx;
  color: #666;
}

/* Input Area Setup */
.input-area {
  background-color: #ffffff;
  padding: 20rpx;
  box-sizing: border-box;
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  background: linear-gradient(180deg, rgba(255,255,255,0) 0%, #ffffff 20%);
}

.input-wrapper {
  display: flex;
  align-items: flex-end;
  width: 100%;
  max-width: 1400rpx;
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 20rpx 30rpx;
  box-shadow: 0 0 30rpx rgba(0, 0, 0, 0.1);
  border: 1px solid rgba(0,0,0,0.1);
  position: relative;
}

.message-input {
  flex: 1;
  font-size: 32rpx;
  min-height: 48rpx;
  max-height: 300rpx;
  line-height: 48rpx;
  width: 100%;
  color: #202123;
}

.input-placeholder {
  color: #8e8ea0;
}

.send-btn {
  width: 60rpx;
  height: 60rpx;
  border-radius: 12rpx;
  background-color: #e5e5e5;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 20rpx;
  flex-shrink: 0;
  transition: all 0.2s;
}

.send-btn.active {
  background-color: #10a37f;
}

.send-icon {
  font-size: 36rpx;
  color: #ffffff;
  font-weight: bold;
}

.footer-tip {
  font-size: 22rpx;
  color: #8e8ea0;
  margin-top: 16rpx;
  margin-bottom: constant(safe-area-inset-bottom);
  margin-bottom: env(safe-area-inset-bottom);
}

/* 正在输入动画 */
.typing-bubble {
  display: flex;
  flex-direction: row;
  align-items: center;
  height: 48rpx;
}

.typing-dot {
  width: 10rpx;
  height: 10rpx;
  background-color: #d1d5db;
  border-radius: 50%;
  margin: 0 6rpx;
  animation: typing 1.4s infinite ease-in-out both;
}

.typing-dot:nth-child(1) {
  animation-delay: -0.32s;
}

.typing-dot:nth-child(2) {
  animation-delay: -0.16s;
}

@keyframes typing {
  0%, 80%, 100% { 
    transform: scale(0);
  } 40% { 
    transform: scale(1.0);
  }
}
