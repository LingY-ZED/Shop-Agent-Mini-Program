/**index.wxss**/
.chat-container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #ffffff;
}

.chat-area {
  flex: 1;
  overflow: hidden;
}

.message-list {
  padding: 28rpx 28rpx 220rpx;
}

.message-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 34rpx;
}

.user-message {
  justify-content: flex-end;
}

.ai-message {
  justify-content: flex-start;
}

.ai-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  margin-right: 18rpx;
  overflow: hidden;
  background: linear-gradient(135deg, #e8f0fe, #d2e3fc);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.avatar-img {
  width: 100%;
  height: 100%;
}

.ai-content {
  max-width: calc(100% - 82rpx);
  margin-top: 6rpx;
  color: #1f1f1f;
  line-height: 1.62;
}

.message-text {
  font-size: 30rpx;
  line-height: 1.65;
  color: #1f1f1f;
  word-break: break-word;
}

.user-bubble {
  max-width: 84%;
  background: #f0f4f9;
  color: #1f1f1f;
  padding: 20rpx 26rpx;
  border-radius: 34rpx 34rpx 8rpx 34rpx;
}

.tool-tag {
  margin-top: 16rpx;
  display: inline-flex;
  padding: 8rpx 14rpx;
  border-radius: 12rpx;
  background: #eef3fb;
}

.tag-text {
  font-size: 24rpx;
  color: #4f5b70;
}

.typing-indicator {
  height: 56rpx;
  display: flex;
  align-items: center;
}

.typing-dot {
  width: 12rpx;
  height: 12rpx;
  margin-right: 10rpx;
  border-radius: 50%;
  background-color: #c4c7c5;
  animation: typing 1.4s infinite ease-in-out both;
}

.typing-dot:nth-child(1) {
  animation-delay: -0.32s;
}

.typing-dot:nth-child(2) {
  animation-delay: -0.16s;
}

.msg-bottom {
  height: 24rpx;
}

.input-area {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 24rpx calc(20rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, rgba(255, 255, 255, 0) 0%, #ffffff 34%);
  box-sizing: border-box;
}

.input-wrapper {
  display: flex;
  align-items: flex-end;
  padding: 14rpx 14rpx 14rpx 24rpx;
  border-radius: 999rpx;
  background: #f0f4f9;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.message-input {
  flex: 1;
  min-height: 46rpx;
  max-height: 220rpx;
  width: 100%;
  font-size: 30rpx;
  line-height: 46rpx;
  color: #1f1f1f;
}

.input-placeholder {
  color: #7f8488;
}

.send-btn {
  width: 70rpx;
  height: 70rpx;
  border-radius: 50%;
  margin-left: 14rpx;
  background: #dfe3e8;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.send-btn.active {
  background: #1a73e8;
}

.send-icon {
  font-size: 38rpx;
  color: #ffffff;
  font-weight: 600;
  transform: translateX(2rpx);
}

@keyframes typing {
  0%,
  80%,
  100% {
    transform: scale(0);
  }

  40% {
    transform: scale(1);
  }
}
